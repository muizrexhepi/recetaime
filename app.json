{
  "expo": {
    "name": "Receta Ime",
    "slug": "recetaime",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "recetaime",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.muiz.recetaime",
      "icon": "./assets/images/icon.png",
      "usesAppleSignIn": true,
      "supportsTablet": false,
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Receta Ime uses your camera to scan handwritten or printed recipes.",
        "NSPhotoLibraryUsageDescription": "Receta Ime uses your photos to import recipe screenshots and saved images.",
        "NSPhotoLibraryAddUsageDescription": "Receta Ime may save recipe images you create or edit."
      }
    },
    "android": {
      "package": "com.muiz.recetaime",
      "adaptiveIcon": {
        "backgroundColor": "#FAF6EA",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": ["CAMERA", "READ_MEDIA_IMAGES", "POST_NOTIFICATIONS"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FAF6EA",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 96,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "Allow Receta Ime to use Face ID."
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Satoshi-Regular.otf",
            "./assets/fonts/Satoshi-Medium.otf",
            "./assets/fonts/Satoshi-Bold.otf"
          ]
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#E94B35"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Receta Ime uses your photos to import recipe screenshots and saved recipe images.",
          "cameraPermission": "Receta Ime uses your camera to scan handwritten or printed recipes."
        }
      ],
      "expo-document-picker",
      "expo-apple-authentication",
      "expo-web-browser",
      [
        "expo-share-intent",
        {
          "iosShareExtensionName": "Import to Receta Ime",
          "iosAppGroupIdentifier": "group.com.muiz.recetaime.share",
          "disableExperimental": true,
          "iosHideView": false,
          "iosActivationRules": {
            "NSExtensionActivationSupportsText": true,
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsWebPageWithMaxCount": 1,
            "NSExtensionActivationSupportsImageWithMaxCount": 1,
            "NSExtensionActivationSupportsMovieWithMaxCount": 1
          },
          "preprocessorInjectJS": "metas['description'] = metas['description'] || document.querySelector('meta[property=\"og:description\"]')?.getAttribute('content') || ''; metas['og:description'] = metas['og:description'] || metas['description']; metas['og:title'] = metas['og:title'] || document.querySelector('meta[property=\"og:title\"]')?.getAttribute('content') || document.title || ''; metas['articleText'] = Array.from(document.querySelectorAll('article, main, [role=\"main\"], h1, h2, p')).map((node) => node.innerText || node.textContent || '').filter(Boolean).join('\\n').slice(0, 12000); metas['bodyText'] = (document.body?.innerText || '').slice(0, 12000);",
          "androidIntentFilters": ["text/*", "image/*", "video/*"],
          "androidMultiIntentFilters": ["image/*"]
        }
      ],
      "./plugins/with-modular-headers"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a07b153b-fe8e-4f5f-8948-027c7b612bcb",
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "ImporttoRecetaIme",
                  "bundleIdentifier": "com.muiz.recetaime.share-extension",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.muiz.recetaime.share"
                    ]
                  }
                }
              ]
            }
          }
        }
      }
    }
  }
}
